# Logging
LOG_LEVEL=info

# ClickHouse
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DATABASE=ontology
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DIAL_TIMEOUT_MS=5000
CLICKHOUSE_WRITE_TIMEOUT_MS=10000
CLICKHOUSE_CONN_MAX_LIFETIME_SEC=3600
CLICKHOUSE_MAX_OPEN_CONNS=10
CLICKHOUSE_MAX_IDLE_CONNS=5

# HTTP server
LISTEN_ADDR=:8080
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=30
HTTP_IDLE_TIMEOUT_SEC=120
HTTP_SHUTDOWN_TIMEOUT_SEC=15

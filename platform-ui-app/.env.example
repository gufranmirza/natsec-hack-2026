# Base URL for the platform-control-plane HTTP API. NEXT_PUBLIC_* so
# both server (env-var inlined at build) and browser can read it.
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8080

# Feature flag — 'true' makes the UI consume live CP reads via the
# cp/* TanStack Query services; 'false' (default) falls back to the
# static src/lib/fixtures/*. Restart Next dev server after changing.
NEXT_PUBLIC_USE_LIVE_CP=false

# Server-side base URL for the platform-control-plane HTTP API.
# Used by server components and src/components/lib/server-api-client.ts.
PLATFORM_API_URL=http://localhost:8081

# Browser-side base URL for the platform-control-plane read API.
# Used by src/services/cp/* TanStack Query hooks via apiClient.
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8081

# Feature flag — when 'true' the UI consumes live CP reads via
# src/services/cp/* hooks; when 'false' (default) it falls back to
# the static src/lib/fixtures/* (laptop demo, no CP container needed).
# Restart Next.js dev server after changing — env loads at boot.
NEXT_PUBLIC_USE_LIVE_CP=false
